# Normalize line endings to LF for all text files.
# Prevents CRLF<->LF churn that bloats diffs on Windows checkouts.
* text=auto eol=lf

# Explicit text types
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.py    text eol=lf
*.xml   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.htaccess text eol=lf

# Binary assets — never normalize
*.webp  binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
